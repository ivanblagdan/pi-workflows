{
	"name": "@ivanblagdan/pi-workflows",
	"version": "0.55.4",
	"description": "Typed workflow primitives built on pi-coding-agent sessions with explicit workflow context control",
	"type": "module",
	"main": "./dist/lib/index.js",
	"types": "./dist/lib/index.d.ts",
	"files": [
		"dist",
		"src",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.55.4",
		"@mariozechner/pi-ai": "^0.55.4",
		"@mariozechner/pi-coding-agent": "^0.55.4",
		"@mariozechner/pi-tui": "^0.55.4",
		"@sinclair/typebox": "^0.34.41"
	},
	"keywords": [
		"workflow",
		"agent",
		"ai",
		"typescript",
		"pi",
		"pi-package"
	],
	"author": "Ivan Blagdan",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ivanblagdan/pi-workflows.git"
	},
	"homepage": "https://github.com/ivanblagdan/pi-workflows#readme",
	"bugs": {
		"url": "https://github.com/ivanblagdan/pi-workflows/issues"
	},
	"pi": {
		"extensions": ["./src/index.ts"]
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"shx": "^0.4.0",
		"typescript": "^5.7.3"
	}
}
